<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aura.Desktop.ViewModels"
        xmlns:converters="using:Aura.Desktop.Converters"
        x:Class="Aura.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Aura"
        Width="950" Height="650"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    
    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>
    
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="300,*">
        
        <!-- LEFT SIDEBAR: Connection + Channels -->
        <Border Grid.Column="0" 
                Background="#181825" 
                BorderBrush="#313244" 
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,25,20,20" Spacing="12">
                     <!-- Simple Logo: Circles and Wave-like shape -->
                    <Grid Width="32" Height="32">
                        <Ellipse Fill="#89B4FA"/>
                        <Path Data="M 12,16 L 16,12 L 20,16 L 16,20 Z" Fill="#1E1E2E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="🔊" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="White" Opacity="0.8"/>
                    </Grid>
                    <TextBlock Text="Aura" 
                               FontSize="22" 
                               FontWeight="Heavy" 
                               Foreground="#CDD6F4"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Connection Panel -->
                <Border Grid.Row="1" Padding="20,0,20,20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="CONNECTION" FontSize="11" FontWeight="Bold" Foreground="#6C7086" Margin="4,0,0,4"/>
                        
                        <!-- Connection Status Badge -->
                        <Border Background="#11111B" 
                                CornerRadius="8" 
                                Padding="12,10"
                                IsVisible="{Binding IsConnected}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Width="8" Height="8" Fill="#a6e3a1"/>
                                <TextBlock Text="{Binding ConnectionStatus}" 
                                           FontSize="13" 
                                           Foreground="#CDD6F4"
                                           FontWeight="Medium"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Server Address + Port -->
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsConnected}">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ServerAddress}"
                                     Watermark="Server Address"
                                     Background="#313244"
                                     Foreground="#CDD6F4"
                                     BorderThickness="0"
                                     CornerRadius="10"
                                     Padding="12,12"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ServerPort}"
                                     Watermark="Port"
                                     Width="80"
                                     Margin="10,0,0,0"
                                     Background="#313244"
                                     Foreground="#CDD6F4"
                                     BorderThickness="0"
                                     CornerRadius="10"
                                     Padding="12,12"/>
                        </Grid>
                        
                        <!-- Server Password -->
                        <TextBox Text="{Binding ServerPassword}"
                                 Watermark="Password (optional)"
                                 PasswordChar="•"
                                 Background="#313244"
                                 Foreground="#CDD6F4"
                                 BorderThickness="0"
                                 CornerRadius="10"
                                 Padding="12,12"
                                 IsVisible="{Binding !IsConnected}"/>
                        
                        <!-- Display Name -->
                        <TextBox Text="{Binding DisplayName}"
                                 Watermark="Display Name"
                                 Background="#313244"
                                 Foreground="#CDD6F4"
                                 BorderThickness="0"
                                 CornerRadius="10"
                                 Padding="12,12"
                                 IsVisible="{Binding !IsConnected}"/>
                        
                        <!-- Connect/Disconnect Button -->
                        <Button Command="{Binding ConnectCommand}"
                                IsVisible="{Binding !IsConnected}"
                                Background="#89B4FA" 
                                Foreground="#1E1E2E"
                                FontWeight="Bold"
                                CornerRadius="10"
                                Padding="20,14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <TextBlock Text="Connect" FontSize="14"/>
                        </Button>
                        
                        <Button Command="{Binding DisconnectCommand}"
                                IsVisible="{Binding IsConnected}"
                                Background="#f38ba8"
                                Foreground="White"
                                FontWeight="Bold"
                                CornerRadius="10"
                                Padding="20,14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <TextBlock Text="Disconnect" FontSize="14"/>
                        </Button>
                        
                        <!-- Status Messages (errors, etc) -->
                        <Border Background="#313244" 
                                CornerRadius="8" 
                                Padding="12,10"
                                IsVisible="{Binding !IsConnected}">
                            <TextBlock Text="{Binding ConnectionStatus}" 
                                       FontSize="12" 
                                       Foreground="#A6ADC8"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Channel List -->
                <ScrollViewer Grid.Row="2" Padding="20,0">
                    <StackPanel Spacing="5">
                        <TextBlock Text="CHANNELS" FontSize="11" FontWeight="Bold" Foreground="#6C7086" Margin="4,0,0,12"/>
                        
                        <ItemsControl ItemsSource="{Binding Channels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:Channel">
                                    <StackPanel Margin="0,0,0,8">
                                        <!-- Channel Header -->
                                        <Button Background="Transparent" 
                                                BorderThickness="0"
                                                HorizontalContentAlignment="Left"
                                                Padding="10,8"
                                                Cursor="Hand"
                                                CornerRadius="8"
                                                Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).JoinChannelCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="🔊" FontSize="16" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="15" 
                                                           Foreground="#CDD6F4"/>
                                            </StackPanel>
                                        </Button>
                                        
                                        <!-- Users in Channel -->
                                        <ItemsControl ItemsSource="{Binding Users}"
                                                      IsVisible="{Binding IsExpanded}"
                                                      Margin="40,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:User">
                                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6">
                                                        <Ellipse Width="8" Height="8" Fill="{Binding IsMuted, Converter={StaticResource BoolToColorConverter}}"/>
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontSize="14"
                                                                   Foreground="#A6ADC8"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Voice Controls -->
                <Border Grid.Row="3" Padding="20">
                    <StackPanel Spacing="12">
                        <ToggleButton IsChecked="{Binding IsMicEnabled}"
                                      Command="{Binding ToggleMicrophoneCommand}"
                                      Background="#313244"
                                      Foreground="#CDD6F4"
                                      CornerRadius="10"
                                      Padding="15,12"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Center"
                                      IsEnabled="{Binding IsAuthenticated}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🎤" FontSize="16"/>
                                <TextBlock Text="Microphone" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </ToggleButton>
                        
                        <!-- Audio Settings Button -->
                        <Button Command="{Binding ToggleAudioSettingsCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                Padding="8,4"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="⚙️" FontSize="12"/>
                                <TextBlock Text="Audio Settings" FontSize="12" Foreground="#6C7086"/>
                            </StackPanel>
                        </Button>
                        
                        <!-- Collapsible Audio Settings Panel -->
                        <Border IsVisible="{Binding ShowAudioSettings}"
                                Background="#11111B"
                                CornerRadius="10"
                                Padding="15">
                            <StackPanel Spacing="12">
                                <TextBlock Text="AUDIO PROCESSING" FontSize="10" FontWeight="Bold" Foreground="#6C7086"/>
                                
                                <!-- RNNoise Toggle -->
                                <CheckBox IsChecked="{Binding RnnoiseEnabled}"
                                          Content="RNNoise Suppression"
                                          Foreground="#CDD6F4"
                                          FontSize="12"/>
                                
                                <!-- AEC Toggle -->
                                <CheckBox IsChecked="{Binding AecEnabled}"
                                          Content="Echo Cancellation (AEC)"
                                          Foreground="#CDD6F4"
                                          FontSize="12"/>
                                
                                <!-- WebRTC NS Toggle -->
                                <CheckBox IsChecked="{Binding WebrtcNsEnabled}"
                                          Content="WebRTC Noise Suppression"
                                          Foreground="#CDD6F4"
                                          FontSize="12"/>
                                
                                <!-- AGC Toggle -->
                                <CheckBox IsChecked="{Binding AgcEnabled}"
                                          Content="Auto Gain Control"
                                          Foreground="#CDD6F4"
                                          FontSize="12"/>
                                
                                <Separator Background="#313244" Height="1" Margin="0,8"/>
                                
                                <TextBlock Text="LATENCY" FontSize="10" FontWeight="Bold" Foreground="#6C7086"/>
                                
                                <!-- DRED Duration -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding DredDuration, StringFormat='DRED Redundancy: {0}0ms'}" 
                                               FontSize="11" Foreground="#A6ADC8"/>
                                    <Slider Minimum="0" Maximum="10" Value="{Binding DredDuration}"
                                            IsSnapToTickEnabled="True" TickFrequency="1"/>
                                </StackPanel>
                                
                                <!-- Jitter Buffer -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding JitterBufferMs, StringFormat='Jitter Buffer: {0}ms'}" 
                                               FontSize="11" Foreground="#A6ADC8"/>
                                    <Slider Minimum="0" Maximum="100" Value="{Binding JitterBufferMs}"
                                            IsSnapToTickEnabled="True" TickFrequency="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="{Binding AudioStats}" 
                                   FontSize="10" 
                                   Foreground="#6C7086"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- MAIN CONTENT: Chat Area -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto" Background="#1E1E2E">
            
            <!-- Messages Area -->
            <ScrollViewer Grid.Row="0" 
                          Padding="30"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChatMessage">
                            <StackPanel Margin="0,4" 
                                        HorizontalAlignment="{Binding IsFromCurrentUser, Converter={x:Static converters:BoolToAlignmentConverter.Instance}}">
                                
                                <!-- User Name (for others only) -->
                                <TextBlock Text="{Binding UserName}"
                                           FontSize="11"
                                           Foreground="#6C7086"
                                           IsVisible="{Binding !IsFromCurrentUser}"
                                           Margin="12,0,0,4"
                                           Opacity="{Binding System, Converter={x:Static converters:BoolToOpacityConverter.Instance}}"/>
                                
                                <Border Background="{Binding ., Converter={x:Static converters:ChatBubbleColorConverter.Instance}}"
                                        BorderThickness="{Binding System, Converter={x:Static converters:BoolToThicknessConverter.Instance}}"
                                        BorderBrush="#313244"
                                        CornerRadius="{Binding System, Converter={x:Static converters:SystemMessageCornerRadiusConverter.Instance}, FallbackValue=18}"
                                        Padding="{Binding System, Converter={x:Static converters:SystemMessagePaddingConverter.Instance}, FallbackValue='16,10'}"
                                        MaxWidth="600"
                                        HorizontalAlignment="{Binding System, Converter={x:Static converters:BoolToAlignmentConverter.CenterIfSystem}}">
                                    <TextBlock Text="{Binding Content}"
                                               Foreground="{Binding ., Converter={x:Static converters:ChatBubbleTextColorConverter.Instance}}"
                                               TextWrapping="Wrap"
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Message Input Bar -->
            <Border Grid.Row="1" 
                    Background="#1E1E2E"
                    Padding="30,10,30,30">
                <Grid ColumnDefinitions="*,Auto">
                    <Border Grid.Column="0" 
                            Background="#181825" 
                            CornerRadius="24"
                            BorderBrush="#313244"
                            BorderThickness="1">
                        <TextBox Text="{Binding MessageInput}"
                                 Watermark="Message..."
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#CDD6F4"
                                 FontSize="15"
                                 Padding="20,12"
                                 VerticalAlignment="Center">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding SendMessageCommand}"/>
                            </TextBox.KeyBindings>
                        </TextBox>
                    </Border>
                    
                    <Button Grid.Column="1" 
                            Command="{Binding SendMessageCommand}"
                            Background="#89B4FA"
                            Width="48" Height="48"
                            CornerRadius="24"
                            Margin="15,0,0,0"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Cursor="Hand">
                        <Path Fill="#1E1E2E" Data="M 24,14 L 24,34 M 24,14 L 16,22 M 24,14 L 32,22" Stroke="#1E1E2E" StrokeThickness="3" StrokeJoin="Round" StrokeLineCap="Round"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
